{
    "name": "@trackflow/api",
    "version": "1.0.0",
    "private": true,
    "description": "TrackFlow API — Node.js + Express + Prisma",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio",
        "lint": "eslint src --ext .ts"
    },
    "dependencies": {
        "@prisma/client": "^6.4.1",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-async-errors": "^3.1.1",
        "helmet": "^8.0.0",
        "express-validator": "^7.2.1",
        "jsonwebtoken": "^9.0.2",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/node": "^22.13.10",
        "eslint": "^9.22.0",
        "prisma": "^6.4.1",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.8.2"
    },
    "prisma": {
        "seed": "ts-node-dev prisma/seed.ts"
    }
}